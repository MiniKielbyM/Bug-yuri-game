  interactableType: 1
  playerSpawnPosition: {x: 0, y: 0, z: 0}
  changeLevel: 0
  nextLevelName: 
  pointer:
    m_PersistentCalls:
      m_Calls: []
  npcDialogueSets:
  - nextSetIndex: 1
    dialogues:
    - npcType: 0
      dialogueText: Hey!
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 1
      dialogueText: Oh!
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 1
      dialogueText: Hey, T.
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 0
      dialogueText: "My armor\u2019s rusting. Can I get new stuff, or\u2026 "
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 1
      dialogueText: Yeah!
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 1
      dialogueText: 'yeah, sure.. '
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 0
      dialogueText: Okay, what for?
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 1
      dialogueText: "Oh uh\u2026 nothing fancy, you can trade in your old stuff."
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 0
      dialogueText: Wait, really? Thanks!
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 1
      dialogueText: So, how's the adventuring going?
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 0
      dialogueText: "It\u2019s been g-"
      function:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 2124387472}
            m_TargetAssemblyTypeName: OBCAppear, Assembly-CSharp
            m_MethodName: appear
            m_Mode: 1
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
          - m_Target: {fileID: 826925273}
            m_TargetAssemblyTypeName: Interactable, Assembly-CSharp
            m_MethodName: FinishCurrentSet
            m_Mode: 1
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
  - nextSetIndex: 2
    dialogues:
    - npcType: 1
      dialogueText: "That\u2019s uh\u2026 well no one actually knows her name"
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 1
      dialogueText: "Just listen to her for a sec. This\u2019ll be interesting."
      function:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 2124387473}
            m_TargetAssemblyTypeName: Interactable, Assembly-CSharp
            m_MethodName: Interact
            m_Mode: 1
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
          - m_Target: {fileID: 826925273}
            m_TargetAssemblyTypeName: Interactable, Assembly-CSharp
            m_MethodName: FinishCurrentSet
            m_Mode: 1
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
  - nextSetIndex: 3
    dialogues:
    - npcType: 0
      dialogueText: I am your grandads clothes
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 0
      dialogueText: Okay.
      function:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 2124387472}
            m_TargetAssemblyTypeName: OBCAppear, Assembly-CSharp
            m_MethodName: disappear
            m_Mode: 1
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    - npcType: 1
      dialogueText: Um.. Tree, swarm, poison.
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 1
      dialogueText: Sounds like she wants you to stop whatever that cult is doing
        on that tree.
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 0
      dialogueText: Cult?
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 1
      dialogueText: "Yeah, the one that\u2019s been putting up flyers advertising
        their current-see for a few weeks."
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 1
      dialogueText: "You\u2019ve been out of town for like, 12 sunsets, so you missed
        it."
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 0
      dialogueText: "You counted how long I\u2019ve been gone? Awww\u2026"
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 1
      dialogueText: "Hehehe\u2026"
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 0
      dialogueText: "What\u2019s a current-see, anyway?"
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 1
      dialogueText: "I don\u2019t know, they\u2019re just using old trash like bottle
        caps, but everyone seems to be going crazy for it."
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 0
      dialogueText: "Strange. Whatever, I\u2019ll take care of it. Just you wait
        and see, baby!!! "
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 1
      dialogueText: "Hehehe\u2026 baby\u2026 heehe"
      function:
        m_PersistentCalls:
          m_Calls: []
  - nextSetIndex: 3
    dialogues:
    - npcType: 1
      dialogueText: "Hehehe\u2026 baby\u2026 heehe"
      function:
        m_PersistentCalls:
          m_Calls: []
  - nextSetIndex: 4
    dialogues:
    - npcType: 0
      dialogueText: Hi Lith!
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 1
      dialogueText: "YOU\u2019RE BACK! Really soon! How was it?"
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 0
      dialogueText: Some idiots were trying to reuse ancient human practices.
      function:
        m_PersistentCalls:
          m_Calls: []
    - npcType: 1
      dialogueText: "Weird\u2026 anyway umm are you okay ? Need any\u2026 thing?"
