--- !u!114 &994461916
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 994461915}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8eb502b09519f4e43990f11c46d24fc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::EnterBossArea
  WallsToActivate:
  - {fileID: 1806699360}
  - {fileID: 1540925048}
  BossIntro:
  - npcType: 1
    dialogueText: Hey!
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: This is an unauthorized area!
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: Authorized area!
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: Get out!
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 0
    dialogueText: Which is it?
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: Whichever one gets you out of here!
    function:
      m_PersistentCalls:
        m_Calls: []
  BossExtro:
  - npcType: 0
    dialogueText: "I\u2019m not leaving until I know what\u2019s going on!"
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 0
    dialogueText: What are you defending?
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: You really want it, huh?
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: "I guess she was right when she told Centi people would go crazy
      for it\u2026 "
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: ...
    function:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 519420033}
          m_TargetAssemblyTypeName: CameraFollowPlayer, Assembly-CSharp
          m_MethodName: LockOnNPC
          m_Mode: 2
          m_Arguments:
            m_ObjectArgument: {fileID: 253579545}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Transform, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - npcType: 0
    dialogueText: "I don\u2019t want your trash!"
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 0
    dialogueText: What are you doing up there?
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: Wow, really?
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: "But it\u2019s super valuable\u2026 you\u2019d be set for life
      with even one of these babies\u2026"
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 0
    dialogueText: "I don\u2019t know what the buzzes you\u2019re talking about, you\u2019re
      making value out of trash that doesn\u2019t matter and you\u2019re expecting
      me to just\u2026 go along with you?"
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: Our system is great, really!
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: "It\u2019s botcoin, short for bottle cap coin, and everyone wants
      it so bad!"
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 0
    dialogueText: "I haven\u2019t seen anyone so much as handle it."
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: "That\u2019s because it\u2019s rare and only for high ranking members."
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: Now if you excuse me, you damaged my wings, so I have to WALK back
      now.
    function:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 1374391513}
          m_TargetAssemblyTypeName: DirectatBossAI, Assembly-CSharp
          m_MethodName: leave
          m_Mode: 1
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  bossDefeated: 0
  dialogueUI: {fileID: 733174501}
  player: {fileID: 803166693}
  boss: {fileID: 1374391507}
  npcSprite: {fileID: -2128982272, guid: 1566ad2cf7b827a419834411cfeb8e5e, type: 3}
  playerSprite: {fileID: -7753673269030977746, guid: eb7246b8c105db148af236dee9209a22, type: 3}
