--- !u!114 &1979818638
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1979818635}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8eb502b09519f4e43990f11c46d24fc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::EnterBossArea
  WallsToActivate:
  - {fileID: 860127151}
  BossIntro:
  - npcType: 0
    dialogueText: HEY!
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: yes?
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 0
    dialogueText: ARE YOU IN THAT CREEPY CULT?
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 0
    dialogueText: THE ONE WITH THE TREE?
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: Why, yes! Have you come to try out our anything machine?
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 0
    dialogueText: YOUR WHAT?
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: Our anything machine! It can do anything.
    function:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 519420033}
          m_TargetAssemblyTypeName: CameraFollowPlayer, Assembly-CSharp
          m_MethodName: LockOnNPC
          m_Mode: 2
          m_Arguments:
            m_ObjectArgument: {fileID: 563952933}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Transform, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - npcType: 0
    dialogueText: "Just looks like a button and a screen to me\u2026"
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: Well it can do anything. Try it!
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 0
    dialogueText: "Um.. NO THANKS! IT\u2019S POURING RUNOFF INTO THE RIVER OVER THERE!"
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 1
    dialogueText: "Well It\u2019s a small sacrifice for anything. Isn\u2019t it?"
    function:
      m_PersistentCalls:
        m_Calls: []
  BossExtro:
  - npcType: 0
    dialogueText: "Finally, it\u2019s dead. Hmm.. there might be moral implications
      to this.."
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 0
    dialogueText: ...
    function:
      m_PersistentCalls:
        m_Calls: []
  - npcType: 0
    dialogueText: "NAHH I don\u2019t feel bad his stuff would\u2019ve wiped us all."
    function:
      m_PersistentCalls:
        m_Calls: []
